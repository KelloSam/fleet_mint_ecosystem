<div class="max-w-2xl mx-auto">
  <div class="mb-6">
    <.link navigate={~p"/freight/clients"} class="text-sm text-gray-500 hover:text-gray-700 flex items-center gap-1">
      <.icon name="hero-arrow-left-solid" class="h-3 w-3" /> Back to Clients
    </.link>
    <h1 class="text-2xl font-bold text-gray-800 mt-2">New Freight Client</h1>
  </div>

  <div class="bg-white rounded-lg shadow p-6">
    <.client_form changeset={@changeset} action={~p"/freight/clients"} />
  </div>
</div>
