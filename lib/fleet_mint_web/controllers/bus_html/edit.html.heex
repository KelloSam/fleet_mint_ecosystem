<div class="mb-6">
  <.link navigate={~p"/buses/#{@bus}"} class="text-sm text-gray-500 hover:text-gray-700 flex items-center gap-1">
    <.icon name="hero-arrow-left-solid" class="h-3 w-3" /> Back to Bus
  </.link>
  <h1 class="text-2xl font-bold text-gray-800 mt-2">Edit Bus — <%= @bus.registration_number %></h1>
</div>

<div class="bg-white rounded-lg shadow p-6">
  <.bus_form changeset={@changeset} action={~p"/buses/#{@bus}"} />
</div>
